// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
  CLIENT
}

enum LeadSource {
  FACEBOOK
  GOOGLE
  INSTAGRAM
  TIKTOK
  LINKEDIN
  ORGANIC
  DIRECT
  WHATSAPP
  REFERRAL
  OTHER
}

// ─── Message Channel (Automation Engine) ─────────────

enum MessageChannel {
  WHATSAPP
  INSTAGRAM
  MESSENGER
}

// ─── Tintim-like Feature Enums ─────────────

enum MetaConversionEvent {
  ViewContent
  Lead
  Purchase
  AddPaymentInfo
  AddToCart
  AddToWishlist
  CompleteRegistration
  Contact
  CustomizeProduct
  Donate
  FindLocation
  InitiateCheckout
  Schedule
  Search
  StartTrial
  SubmitApplication
  Subscribe
}

enum WebhookEventType {
  NEW_LEAD
  LEAD_STAGE_CHANGE
  SALE_COMPLETED
  LEAD_UPDATED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SOLD
  LOST
}

enum PlatformType {
  FACEBOOK
  INSTAGRAM
  GOOGLE_ADS
  TIKTOK
  LINKEDIN
  TWITTER
  PINTEREST
  SNAPCHAT
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
  DRAFT
}

enum AlertType {
  PERFORMANCE
  STATUS
  OPPORTUNITY
}

enum AlertAction {
  EMAIL
  IN_APP
  PAUSE_CAMPAIGN
  WEBHOOK
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          UserRole @default(ANALYST)
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  platforms         Platform[]
  platformLogins    PlatformLogin[]
  alerts            Alert[]
  reports           Report[]
  aiConversations   AIConversation[]
  notifications     Notification[]
  automationRules   AutomationRule[]
  auditLogs         AuditLog[]
  whatsappGroups    WhatsAppGroup[]
  clients           Client[]
  apiLogs           ApiLog[]
  budgetCaps        PlatformBudgetCap[]
  abTests           ABTest[]
  audiences         Audience[]
  campaignSchedules CampaignSchedule[]
  trackingLinks     TrackingLink[]
  leads             Lead[]
  trackingApiKey    String?          @unique

  // Tintim features
  journeyStages        JourneyStage[]
  conversionEvents     ConversionEventConfig[]
  pixelConfigs         PixelConfig[]
  webhookEndpoints     WebhookEndpoint[]
  trackableMessages    TrackableMessage[]
  sharedClientAccess   ClientAccess[]

  @@index([email])
  @@map("users")
}

model PlatformLogin {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformType     PlatformType
  accessToken      String       // Encrypted token
  refreshToken     String?
  tokenExpiresAt   DateTime?
  externalUserId   String       // Platform-specific user/account ID
  externalUserName String?      // Profile/account display name
  platformMetadata Json?        // Platform-specific data (BMs for FB, MCC for Google, etc.)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  platforms        Platform[]   // Ad accounts linked to this login

  @@unique([userId, platformType, externalUserId])
  @@index([userId])
  @@map("platform_logins")
}

model Platform {
  id              String       @id @default(cuid())
  type            PlatformType
  name            String       // e.g., "My Facebook Ads Account"

  // OAuth tokens (encrypted)
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime?

  // Platform-specific IDs
  externalId      String       // e.g., Facebook Ad Account ID

  isConnected     Boolean      @default(true)
  lastSyncAt      DateTime?

  // Login & BM association
  platformLoginId     String?
  platformLogin       PlatformLogin? @relation(fields: [platformLoginId], references: [id], onDelete: SetNull)
  businessManagerId   String?
  businessManagerName String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns       Campaign[]
  audiences       Audience[]
  clientId        String?
  client          Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  trackingLinks   TrackingLink[]
  leads           Lead[]

  @@unique([userId, type, externalId])
  @@index([userId])
  @@index([type])
  @@index([platformLoginId])
  @@index([clientId])
  @@map("platforms")
}

model Campaign {
  id              String         @id @default(cuid())

  // Campaign Info
  externalId      String?        // Platform's campaign ID (null for drafts)
  name            String
  status          CampaignStatus
  draftData       Json?          // Stores objective, targeting, creative config before publishing

  // Budget
  dailyBudget     Float?
  lifetimeBudget  Float?
  currency        String         @default("USD")

  // Dates
  startDate       DateTime?
  endDate         DateTime?

  // Platform info
  platformType    PlatformType

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  platformId      String
  platform        Platform       @relation(fields: [platformId], references: [id], onDelete: Cascade)
  metrics         Metric[]
  adCreatives     AdCreative[]
  adSets          AdSet[]
  tags            CampaignTag[]
  schedules       CampaignSchedule[]
  trackingLinks   TrackingLink[]
  leads           Lead[]

  @@unique([platformId, externalId])
  @@index([platformId])
  @@index([platformType])
  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model AdCreative {
  id              String   @id @default(cuid())

  externalId      String   // Platform's creative ID
  name            String?
  thumbnailUrl    String?
  imageUrl        String?
  body            String?  // Ad text/copy
  title           String?  // Ad headline

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads             Ad[]

  @@unique([campaignId, externalId])
  @@index([campaignId])
  @@map("ad_creatives")
}

model AdSet {
  id              String         @id @default(cuid())
  externalId      String
  name            String
  status          CampaignStatus
  dailyBudget     Float?
  lifetimeBudget  Float?
  targeting       Json?
  optimizationGoal String?
  billingEvent    String?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaignId      String
  campaign        Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads             Ad[]

  @@unique([campaignId, externalId])
  @@index([campaignId])
  @@index([status])
  @@map("ad_sets")
}

model Ad {
  id              String         @id @default(cuid())
  externalId      String
  name            String
  status          CampaignStatus
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  adSetId         String
  adSet           AdSet          @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creativeId      String?
  creative        AdCreative?    @relation(fields: [creativeId], references: [id])

  @@unique([adSetId, externalId])
  @@index([adSetId])
  @@index([status])
  @@map("ads")
}

model Metric {
  id              String   @id @default(cuid())

  // Date range
  date            DateTime

  // Core metrics
  impressions     BigInt   @default(0)
  reach           BigInt   @default(0)
  clicks          BigInt   @default(0)
  spend           Float    @default(0)
  conversions     Int      @default(0)

  // Calculated metrics (stored for performance)
  ctr             Float    @default(0) // Click-through rate
  cpc             Float    @default(0) // Cost per click
  cpm             Float    @default(0) // Cost per mille (1000 impressions)
  conversionRate  Float    @default(0)
  roas            Float    @default(0) // Return on ad spend
  revenue         Float    @default(0)

  // Additional metrics (platform-specific)
  metadata        Json?    // For storing platform-specific metrics

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
  @@map("metrics")
}

model Alert {
  id              String        @id @default(cuid())

  name            String
  description     String?
  type            AlertType
  isActive        Boolean       @default(true)

  // Conditions (stored as JSON)
  conditions      Json          // { metric: 'roas', operator: '<', value: 2 }

  // Actions
  actions         AlertAction[]

  // Target
  targetPlatforms PlatformType[]

  // Notification settings
  emailTo         String[]
  webhookUrl      String?

  // Tracking
  lastTriggeredAt DateTime?
  triggerCount    Int           @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("alerts")
}

model Report {
  id              String       @id @default(cuid())

  title           String
  template        String       // 'executive', 'detailed', 'platform', etc.

  // Configuration
  config          Json         // Date range, filters, selected metrics, etc.

  status          ReportStatus @default(PENDING)

  // File info
  fileUrl         String?
  fileFormat      String?      // 'pdf' or 'xlsx'

  // Scheduling
  isScheduled     Boolean      @default(false)
  scheduleConfig  Json?        // cron expression, recipients, etc.
  nextRunAt       DateTime?

  // Tracking
  generatedAt     DateTime?
  error           String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
  @@map("reports")
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// AI Agent Models

enum AIProvider {
  CLAUDE
  OPENAI
}

enum AIActionType {
  PAUSE_CAMPAIGN
  ACTIVATE_CAMPAIGN
  UPDATE_BUDGET
  CREATE_CAMPAIGN
}

enum AIActionStatus {
  PENDING
  APPROVED
  EXECUTED
  REJECTED
  FAILED
}

model AIConversation {
  id          String     @id @default(cuid())
  title       String?
  provider    AIProvider @default(CLAUDE)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AIMessage[]
  actions     AIAction[]

  @@index([userId])
  @@index([createdAt])
  @@map("ai_conversations")
}

model AIMessage {
  id              String   @id @default(cuid())
  role            String   // 'user' | 'assistant'
  content         String
  structuredData  Json?    // Parsed actions, metrics context, etc.

  createdAt       DateTime @default(now())

  // Relations
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AIAction {
  id              String         @id @default(cuid())
  type            AIActionType
  status          AIActionStatus @default(PENDING)
  campaignId      String?
  parameters      Json?          // { dailyBudget: 50, etc. }
  reason          String?        // Why the AI suggested this

  executedAt      DateTime?
  error           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
  @@map("ai_actions")
}

// Notifications

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  metadata  Json?

  createdAt DateTime         @default(now())

  // Relations
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId])
  @@map("notifications")
}

// Automation Rules
enum AutomationRuleStatus {
  ACTIVE
  PAUSED
  DELETED
}

model AutomationRule {
  id              String               @id @default(cuid())
  name            String
  description     String?
  status          AutomationRuleStatus @default(ACTIVE)

  // Rule type
  ruleType        String               @default("simple") // simple|compound|scaling|dayparting|anomaly|auto_restart

  // Condition: metric, operator, value, period (used by simple rules)
  metric          String               // 'ctr', 'cpc', 'roas', 'spend', 'cpm', 'conversions'
  operator        String               // 'lt', 'gt', 'lte', 'gte', 'eq'
  value           Float
  periodDays      Int                  @default(3) // Evaluate over X days

  // Compound rule conditions
  conditions      Json?                // [{metric,operator,value,periodDays}] for compound rules
  conditionLogic  String?              // 'AND' | 'OR'

  // Type-specific configuration (scaling, dayparting, anomaly, auto_restart)
  config          Json?

  // Action to take when condition is met
  actionType      String               // 'pause', 'activate', 'increase_budget', 'decrease_budget', 'notify', 'webhook'
  actionValue     Float?               // e.g., percentage for budget changes

  // Webhook action fields
  webhookUrl      String?
  webhookHeaders  Json?

  // Scope: which campaigns this rule applies to
  applyTo         String               @default("all") // 'all', 'active', 'specific'
  campaignIds     String[]             // If applyTo = 'specific'
  platformTypes   PlatformType[]

  // Execution tracking
  lastRunAt       DateTime?
  lastTriggeredAt DateTime?
  triggerCount    Int                  @default(0)
  executionLog    Json?                // Last execution results

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("automation_rules")
}

// Platform Budget Caps
model PlatformBudgetCap {
  id                 String       @id @default(cuid())
  platformType       PlatformType
  dailyCapAmount     Float?
  weeklyCapAmount    Float?
  currentDailySpend  Float        @default(0)
  currentWeeklySpend Float        @default(0)
  lastResetDay       DateTime?
  lastResetWeek      DateTime?
  isActive           Boolean      @default(true)

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformType])
  @@index([userId])
  @@map("platform_budget_caps")
}

// A/B Tests
enum ABTestStatus {
  RUNNING
  EVALUATING
  COMPLETED
  CANCELLED
}

model ABTest {
  id               String       @id @default(cuid())
  name             String
  status           ABTestStatus @default(RUNNING)
  campaignIds      String[]
  metric           String       // metric to compare: 'ctr', 'cpc', 'roas', 'conversions'
  evaluationDays   Int          @default(7)
  totalDailyBudget Float?
  winnerId         String?      // campaign ID of the winner
  results          Json?        // comparison results
  startedAt        DateTime     @default(now())
  evaluateAt       DateTime     // when to evaluate
  completedAt      DateTime?

  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([evaluateAt])
  @@index([userId])
  @@map("ab_tests")
}

// Campaign Tags
model CampaignTag {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#6B7280") // hex color

  createdAt  DateTime @default(now())

  // Relations
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String

  @@unique([campaignId, name])
  @@index([campaignId])
  @@index([userId])
  @@map("campaign_tags")
}

// Audit Log
model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   // 'campaign', 'platform', 'automation_rule'
  entityId    String
  action      String   // 'status_changed', 'budget_updated', 'created', 'deleted', 'rule_triggered'
  oldValue    Json?
  newValue    Json?
  source      String   @default("manual") // 'manual', 'ai_agent', 'automation_rule', 'sync'
  description String?

  createdAt   DateTime @default(now())

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── WhatsApp Groups (Evolution API integration) ─────────────

model WhatsAppGroup {
  id          String   @id @default(cuid())
  groupJid    String   // "120363...@g.us" - WhatsApp group ID
  groupName   String
  clientName  String
  isActive    Boolean  @default(true)

  platformIds String[] // Platform IDs whose campaigns notify this group

  // Notification preferences
  notifyStatusChange  Boolean @default(true)
  notifyBudgetChange  Boolean @default(true)
  notifyPerformance   Boolean @default(true)
  notifyDailySummary  Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@map("whatsapp_groups")
}

// ─── Custom Audiences ─────────────

enum AudienceStatus {
  PROCESSING
  READY
  ERROR
}

model Audience {
  id               String         @id @default(cuid())
  name             String
  description      String?
  externalId       String?        // Facebook Custom Audience ID
  status           AudienceStatus @default(PROCESSING)
  errorMessage     String?
  emailCount       Int            @default(0)
  approximateSize  Int?           // Facebook's approximate_count
  source           String?        // e.g., "csv_upload", "manual_paste"

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformId       String
  platform         Platform       @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platformId])
  @@index([status])
  @@map("audiences")
}

// ─── Campaign Library (Best Practices Knowledge Base) ─────────────

model CampaignTemplate {
  id              String   @id @default(cuid())

  // Classification
  name            String
  niche           String   // e-commerce, infoprodutos, saas, servicos-locais, imobiliario, saude, educacao, financas, moda, restaurantes
  platform        String   // FACEBOOK, GOOGLE_ADS, TIKTOK, LINKEDIN, MULTI
  objective       String   // conversao, trafego, mensagens, leads, reconhecimento, engajamento, vendas-catalogo
  category        String   // bdcap, asc, cbo, abo, performance-max, spark-ads, lead-gen, remarketing, lookalike

  // Campaign structure
  campaignSetup   Json     // { buyingType, optimizationGoal, bidStrategy, budgetType, budgetRange, specialAdCategories }
  adSetSetup      Json     // { targeting, placements, schedule, optimizationEvent, attribution }
  creativeSetup   Json     // { format, specs, copyTemplates, visualGuidelines, ctaOptions, hooks }

  // Performance benchmarks
  benchmarks      Json     // { ctr, cpc, cpm, cpa, roas, conversionRate, cplead }

  // Content
  description     String   @db.Text
  strategy        String   @db.Text  // Detailed strategy explanation
  tips            String[] // Array of pro tips
  commonMistakes  String[] // What NOT to do
  scalingGuide    String?  @db.Text  // How to scale after validation

  // Metadata
  source          String?  // Where the best practice comes from
  year            Int      @default(2025)
  difficulty      String   @default("intermediario") // iniciante, intermediario, avancado
  verified        Boolean  @default(true)
  rating          Float    @default(4.5)
  thumbnailUrl    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([niche])
  @@index([platform])
  @@index([objective])
  @@index([category])
  @@map("campaign_templates")
}

// ─── Client Management ─────────────

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  notes     String?  @db.Text
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  platforms      Platform[]
  whatsappGroups WhatsAppGroup[]
  leads          Lead[]
  accessShares   ClientAccess[]

  @@index([userId])
  @@map("clients")
}

// ─── API Logs ─────────────

model ApiLog {
  id             String        @id @default(cuid())
  method         String
  url            String
  requestBody    Json?
  responseStatus Int?
  responseBody   Json?
  duration       Int?          // milliseconds
  error          String?
  platformType   PlatformType?
  platformId     String?
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("api_logs")
}

// ─── Campaign Schedules (Pause/Resume scheduling) ─────────────

model CampaignSchedule {
  id              String   @id @default(cuid())
  type            String   @default("once")  // "once" | "recurring"
  pauseDuration   Int      // minutes
  resumeDuration  Int?     // minutes (recurring only: active time before pausing again)
  status          String   @default("active") // active | paused_waiting | completed | cancelled
  currentAction   String?  // "paused" | "resumed"
  jobId           String?  // Bull job ID
  nextActionAt    DateTime?
  executionCount  Int      @default(0)
  maxExecutions   Int?     // null = infinite
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("campaign_schedules")
}

// ─── Lead Tracking ─────────────

model TrackingLink {
  id              String    @id @default(cuid())
  shortCode       String    @unique
  name            String
  destinationUrl  String

  // UTM Parameters
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?

  // Custom parameters (ad_id, adset_id, etc)
  customParams    Json?

  // WhatsApp / Meta Ads fields
  whatsappMessage       String?   // Initial WhatsApp message
  whatsappRedirect      String?   @default("app") // "app" or "web"
  isMetaAds             Boolean   @default(false)
  redirectPageTitle     String?
  redirectPageMessage   String?
  whatsappNumber        String?

  // Denormalized counters
  totalClicks     Int       @default(0)
  uniqueClicks    Int       @default(0)

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId      String?
  campaign        Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  platformId      String?
  platform        Platform? @relation(fields: [platformId], references: [id], onDelete: SetNull)
  clicks          Click[]
  leads           Lead[]

  @@index([shortCode])
  @@index([userId])
  @@index([campaignId])
  @@map("tracking_links")
}

model Click {
  id              String       @id @default(cuid())
  ipAddress       String?
  userAgent       String?
  referer         String?
  fingerprint     String?      // hash(ip + userAgent)

  createdAt       DateTime     @default(now())

  // Relations
  trackingLinkId  String
  trackingLink    TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)

  @@index([trackingLinkId])
  @@index([createdAt])
  @@index([trackingLinkId, fingerprint])
  @@map("clicks")
}

model Lead {
  id              String      @id @default(cuid())
  name            String?
  phone           String?
  email           String?

  source          LeadSource  @default(OTHER)
  status          LeadStatus  @default(NEW)
  value           Float?

  // UTM Parameters (captured at lead creation)
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?

  // Preparation for future WhatsApp module
  whatsappConversationId String?

  metadata        Json?
  notes           String?     @db.Text

  // Journey tracking
  currentJourneyStageId String?
  currentJourneyStage   JourneyStage? @relation(fields: [currentJourneyStageId], references: [id], onDelete: SetNull)
  journeyLogs           LeadJourneyLog[]
  conversationMessages  ConversationMessage[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackingLinkId  String?
  trackingLink    TrackingLink? @relation(fields: [trackingLinkId], references: [id], onDelete: SetNull)
  campaignId      String?
  campaign        Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  platformId      String?
  platform        Platform?   @relation(fields: [platformId], references: [id], onDelete: SetNull)
  clientId        String?
  client          Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([campaignId])
  @@index([phone])
  @@index([currentJourneyStageId])
  @@map("leads")
}

// ─── Journey Stages (Tintim) ─────────────

model JourneyStage {
  id               String              @id @default(cuid())
  name             String
  funnelOrder      Int
  conversionEvent  MetaConversionEvent?
  isSaleStage      Boolean             @default(false)
  isFirstContact   Boolean             @default(false)
  triggerKeyword   String?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  leads            Lead[]
  journeyLogs      LeadJourneyLog[]
  conversionEvents ConversionEventConfig[]

  @@index([userId])
  @@index([funnelOrder])
  @@map("journey_stages")
}

model LeadJourneyLog {
  id              String       @id @default(cuid())
  changedBy       String?      // "system" | "manual" | user name
  metadata        Json?

  createdAt       DateTime     @default(now())

  leadId          String
  lead            Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  journeyStageId  String
  journeyStage    JourneyStage @relation(fields: [journeyStageId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([journeyStageId])
  @@map("lead_journey_logs")
}

// ─── Conversion Event Config (Tintim) ─────────────

model ConversionEventConfig {
  id                     String              @id @default(cuid())
  name                   String
  platform               String              // "meta" | "google"
  metaEventName          MetaConversionEvent?
  metaPixelId            String?
  metaAccessToken        String?
  googleConversionAction String?
  googleCustomerId       String?
  isActive               Boolean             @default(true)
  autoSend               Boolean             @default(false)

  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  userId                 String
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  journeyStageId         String?
  journeyStage           JourneyStage?       @relation(fields: [journeyStageId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([journeyStageId])
  @@map("conversion_event_configs")
}

// ─── Pixel Config (Tintim) ─────────────

model PixelConfig {
  id            String   @id @default(cuid())
  platform      String   // "meta" | "google"
  pixelId       String
  accessToken   String
  testEventCode String?
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pixel_configs")
}

// ─── Webhook Endpoints (Tintim) ─────────────

model WebhookEndpoint {
  id         String             @id @default(cuid())
  name       String
  url        String
  secret     String?
  isActive   Boolean            @default(true)
  events     WebhookEventType[]
  retryCount Int                @default(3)
  timeoutMs  Int                @default(5000)
  stats      Json?              // { totalSent, totalSuccess, totalFailed, lastSentAt }

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id             String          @id @default(cuid())
  eventType      WebhookEventType
  payload        Json
  responseStatus Int?
  responseBody   String?         @db.Text
  success        Boolean         @default(false)
  duration       Int?            // ms
  error          String?
  attempt        Int             @default(1)

  createdAt      DateTime        @default(now())

  endpointId     String
  endpoint       WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// ─── Trackable Messages (Tintim) ─────────────

model TrackableMessage {
  id              String   @id @default(cuid())
  name            String
  messageTemplate String   @db.Text
  gclid           String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trackable_messages")
}

// ─── Conversation Messages (Automation Engine) ─────────────

model ConversationMessage {
  id         String         @id @default(cuid())
  externalId String         // Platform message ID
  channel    MessageChannel
  direction  String         @default("inbound") // "inbound" | "outbound"
  content    String?        @db.Text
  senderName String?
  senderId   String?        // Platform-specific sender ID
  metadata   Json?

  createdAt  DateTime       @default(now())

  leadId     String
  lead       Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([externalId, channel])
  @@index([leadId])
  @@index([createdAt])
  @@map("conversation_messages")
}

// ─── Client Access Sharing (Tintim) ─────────────

model ClientAccess {
  id        String   @id @default(cuid())
  role      String   @default("viewer") // "viewer" | "editor" | "admin"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
  @@map("client_access")
}
