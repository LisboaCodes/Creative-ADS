// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
  CLIENT
}

enum PlatformType {
  FACEBOOK
  INSTAGRAM
  GOOGLE_ADS
  TIKTOK
  LINKEDIN
  TWITTER
  PINTEREST
  SNAPCHAT
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
}

enum AlertType {
  PERFORMANCE
  STATUS
  OPPORTUNITY
}

enum AlertAction {
  EMAIL
  IN_APP
  PAUSE_CAMPAIGN
  WEBHOOK
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String
  role          UserRole @default(ANALYST)
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  platforms         Platform[]
  platformLogins    PlatformLogin[]
  alerts            Alert[]
  reports           Report[]
  aiConversations   AIConversation[]
  notifications     Notification[]
  automationRules   AutomationRule[]
  auditLogs         AuditLog[]

  @@index([email])
  @@map("users")
}

model PlatformLogin {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformType     PlatformType
  accessToken      String       // Encrypted token
  refreshToken     String?
  tokenExpiresAt   DateTime?
  externalUserId   String       // Platform-specific user/account ID
  externalUserName String?      // Profile/account display name
  platformMetadata Json?        // Platform-specific data (BMs for FB, MCC for Google, etc.)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  platforms        Platform[]   // Ad accounts linked to this login

  @@unique([userId, platformType, externalUserId])
  @@index([userId])
  @@map("platform_logins")
}

model Platform {
  id              String       @id @default(cuid())
  type            PlatformType
  name            String       // e.g., "My Facebook Ads Account"

  // OAuth tokens (encrypted)
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime?

  // Platform-specific IDs
  externalId      String       // e.g., Facebook Ad Account ID

  isConnected     Boolean      @default(true)
  lastSyncAt      DateTime?

  // Login & BM association
  platformLoginId     String?
  platformLogin       PlatformLogin? @relation(fields: [platformLoginId], references: [id], onDelete: SetNull)
  businessManagerId   String?
  businessManagerName String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns       Campaign[]

  @@unique([userId, type, externalId])
  @@index([userId])
  @@index([type])
  @@index([platformLoginId])
  @@map("platforms")
}

model Campaign {
  id              String         @id @default(cuid())

  // Campaign Info
  externalId      String         // Platform's campaign ID
  name            String
  status          CampaignStatus

  // Budget
  dailyBudget     Float?
  lifetimeBudget  Float?
  currency        String         @default("USD")

  // Dates
  startDate       DateTime?
  endDate         DateTime?

  // Platform info
  platformType    PlatformType

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  platformId      String
  platform        Platform       @relation(fields: [platformId], references: [id], onDelete: Cascade)
  metrics         Metric[]
  adCreatives     AdCreative[]
  tags            CampaignTag[]

  @@unique([platformId, externalId])
  @@index([platformId])
  @@index([platformType])
  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model AdCreative {
  id              String   @id @default(cuid())

  externalId      String   // Platform's creative ID
  name            String?
  thumbnailUrl    String?
  imageUrl        String?
  body            String?  // Ad text/copy
  title           String?  // Ad headline

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, externalId])
  @@index([campaignId])
  @@map("ad_creatives")
}

model Metric {
  id              String   @id @default(cuid())

  // Date range
  date            DateTime

  // Core metrics
  impressions     BigInt   @default(0)
  reach           BigInt   @default(0)
  clicks          BigInt   @default(0)
  spend           Float    @default(0)
  conversions     Int      @default(0)

  // Calculated metrics (stored for performance)
  ctr             Float    @default(0) // Click-through rate
  cpc             Float    @default(0) // Cost per click
  cpm             Float    @default(0) // Cost per mille (1000 impressions)
  conversionRate  Float    @default(0)
  roas            Float    @default(0) // Return on ad spend
  revenue         Float    @default(0)

  // Additional metrics (platform-specific)
  metadata        Json?    // For storing platform-specific metrics

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
  @@map("metrics")
}

model Alert {
  id              String        @id @default(cuid())

  name            String
  description     String?
  type            AlertType
  isActive        Boolean       @default(true)

  // Conditions (stored as JSON)
  conditions      Json          // { metric: 'roas', operator: '<', value: 2 }

  // Actions
  actions         AlertAction[]

  // Target
  targetPlatforms PlatformType[]

  // Notification settings
  emailTo         String[]
  webhookUrl      String?

  // Tracking
  lastTriggeredAt DateTime?
  triggerCount    Int           @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("alerts")
}

model Report {
  id              String       @id @default(cuid())

  title           String
  template        String       // 'executive', 'detailed', 'platform', etc.

  // Configuration
  config          Json         // Date range, filters, selected metrics, etc.

  status          ReportStatus @default(PENDING)

  // File info
  fileUrl         String?
  fileFormat      String?      // 'pdf' or 'xlsx'

  // Scheduling
  isScheduled     Boolean      @default(false)
  scheduleConfig  Json?        // cron expression, recipients, etc.
  nextRunAt       DateTime?

  // Tracking
  generatedAt     DateTime?
  error           String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([nextRunAt])
  @@map("reports")
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// AI Agent Models

enum AIProvider {
  CLAUDE
  OPENAI
}

enum AIActionType {
  PAUSE_CAMPAIGN
  ACTIVATE_CAMPAIGN
  UPDATE_BUDGET
  CREATE_CAMPAIGN
}

enum AIActionStatus {
  PENDING
  APPROVED
  EXECUTED
  REJECTED
  FAILED
}

model AIConversation {
  id          String     @id @default(cuid())
  title       String?
  provider    AIProvider @default(CLAUDE)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    AIMessage[]
  actions     AIAction[]

  @@index([userId])
  @@index([createdAt])
  @@map("ai_conversations")
}

model AIMessage {
  id              String   @id @default(cuid())
  role            String   // 'user' | 'assistant'
  content         String
  structuredData  Json?    // Parsed actions, metrics context, etc.

  createdAt       DateTime @default(now())

  // Relations
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AIAction {
  id              String         @id @default(cuid())
  type            AIActionType
  status          AIActionStatus @default(PENDING)
  campaignId      String?
  parameters      Json?          // { dailyBudget: 50, etc. }
  reason          String?        // Why the AI suggested this

  executedAt      DateTime?
  error           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([status])
  @@map("ai_actions")
}

// Notifications

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  metadata  Json?

  createdAt DateTime         @default(now())

  // Relations
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// Automation Rules
enum AutomationRuleStatus {
  ACTIVE
  PAUSED
  DELETED
}

model AutomationRule {
  id              String               @id @default(cuid())
  name            String
  description     String?
  status          AutomationRuleStatus @default(ACTIVE)

  // Condition: metric, operator, value, period
  metric          String               // 'ctr', 'cpc', 'roas', 'spend', 'cpm', 'conversions'
  operator        String               // 'lt', 'gt', 'lte', 'gte', 'eq'
  value           Float
  periodDays      Int                  @default(3) // Evaluate over X days

  // Action to take when condition is met
  actionType      String               // 'pause', 'activate', 'increase_budget', 'decrease_budget', 'notify'
  actionValue     Float?               // e.g., percentage for budget changes

  // Scope: which campaigns this rule applies to
  applyTo         String               @default("all") // 'all', 'active', 'specific'
  campaignIds     String[]             // If applyTo = 'specific'
  platformTypes   PlatformType[]

  // Execution tracking
  lastRunAt       DateTime?
  lastTriggeredAt DateTime?
  triggerCount    Int                  @default(0)
  executionLog    Json?                // Last execution results

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("automation_rules")
}

// Campaign Tags
model CampaignTag {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#6B7280") // hex color

  createdAt  DateTime @default(now())

  // Relations
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String

  @@unique([campaignId, name])
  @@index([campaignId])
  @@index([userId])
  @@map("campaign_tags")
}

// Audit Log
model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   // 'campaign', 'platform', 'automation_rule'
  entityId    String
  action      String   // 'status_changed', 'budget_updated', 'created', 'deleted', 'rule_triggered'
  oldValue    Json?
  newValue    Json?
  source      String   @default("manual") // 'manual', 'ai_agent', 'automation_rule', 'sync'
  description String?

  createdAt   DateTime @default(now())

  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Campaign Library (Best Practices Knowledge Base) ─────────────

model CampaignTemplate {
  id              String   @id @default(cuid())

  // Classification
  name            String
  niche           String   // e-commerce, infoprodutos, saas, servicos-locais, imobiliario, saude, educacao, financas, moda, restaurantes
  platform        String   // FACEBOOK, GOOGLE_ADS, TIKTOK, LINKEDIN, MULTI
  objective       String   // conversao, trafego, mensagens, leads, reconhecimento, engajamento, vendas-catalogo
  category        String   // bdcap, asc, cbo, abo, performance-max, spark-ads, lead-gen, remarketing, lookalike

  // Campaign structure
  campaignSetup   Json     // { buyingType, optimizationGoal, bidStrategy, budgetType, budgetRange, specialAdCategories }
  adSetSetup      Json     // { targeting, placements, schedule, optimizationEvent, attribution }
  creativeSetup   Json     // { format, specs, copyTemplates, visualGuidelines, ctaOptions, hooks }

  // Performance benchmarks
  benchmarks      Json     // { ctr, cpc, cpm, cpa, roas, conversionRate, cplead }

  // Content
  description     String   @db.Text
  strategy        String   @db.Text  // Detailed strategy explanation
  tips            String[] // Array of pro tips
  commonMistakes  String[] // What NOT to do
  scalingGuide    String?  @db.Text  // How to scale after validation

  // Metadata
  source          String?  // Where the best practice comes from
  year            Int      @default(2025)
  difficulty      String   @default("intermediario") // iniciante, intermediario, avancado
  verified        Boolean  @default(true)
  rating          Float    @default(4.5)
  thumbnailUrl    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([niche])
  @@index([platform])
  @@index([objective])
  @@index([category])
  @@map("campaign_templates")
}
